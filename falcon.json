{
  "$schema": "https://raw.githubusercontent.com/JacobDevelops/dart_falcon/main/schema/falcon.schema.json",
  "files": {
    "includes": ["**", "!.dart_tool/**", "!build/**", "!**/*.g.dart", "!**/*.freezed.dart"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "complexity": {
        "avoid-unnecessary-containers": "warn",
        "unnecessary-overrides": "warn",
        "avoid-function-literals-in-foreach-calls": "warn",
        "prefer-conditional-assignment": "warn",
        "prefer-for-elements-to-map-from-iterable": "warn",
        "prefer-if-null-operators": "warn",
        "prefer-null-aware-operators": "warn",
        "unnecessary-const": "warn",
        "unnecessary-getters-setters": "warn",
        "avoid-nested-conditional-expressions": "warn",
        "avoid-redundant-async": "warn",
        "avoid-unnecessary-type-assertions": "warn",
        "avoid-unnecessary-type-casts": "warn",
        "avoid-inverted-boolean-expressions": "warn",
        "avoid-nested-if": "warn",
        "cyclomatic-complexity": "warn",
        "max-lines-for-file": "warn",
        "max-lines-for-function": "warn",
        "max-parameters-for-function": "warn",
        "max-switch-cases": "warn",
        "maximum-nesting-level": "warn",
        "no-boolean-literal-compare": "warn",
        "prefer-conditional-expressions": "warn",
        "prefer-extracting-callbacks": "warn",
        "prefer-immediate-return": "warn",
        "prefer-moving-to-variable": "warn",
        "prefer-iterable-any": "warn",
        "prefer-iterable-every": "warn"
      },
      "correctness": {
        "avoid-web-libraries-in-flutter": "warn",
        "no-logic-in-create-state": "warn",
        "avoid-relative-lib-imports": "warn",
        "hash-and-equals": "warn",
        "valid-regexps": "warn",
        "implementation-imports": "warn",
        "avoid-global-state": "warn",
        "avoid-returning-widgets": "warn",
        "avoid-unused-parameters": "warn",
        "avoid-mutable-global-variables": "warn",
        "correct-order-for-super-dispose": "warn",
        "proper-controller-dispose": "warn",
        "proper-expanded-and-flexible": "warn",
        "proper-from-environment": "warn",
        "proper-super-init-state": "warn",
        "unnecessary-flutter-imports": "warn",
        "unnecessary-nullable-return-type": "warn",
        "use-once-constructors-once-provider": "warn"
      },
      "performance": {
        "sized-box-for-whitespace": "warn",
        "unnecessary-to-list-in-spreads": "warn",
        "prefer-const-border-radius": "warn",
        "prefer-correct-edge-insets-constructor": "warn",
        "prefer-declaring-const-constructor": "warn"
      },
      "style": {
        "sort-child-properties-last": "warn",
        "use-full-hex-values-for-flutter-colors": "warn",
        "camel-case-extensions": "warn",
        "camel-case-types": "warn",
        "curly-braces-in-flow-control-structures": "warn",
        "dangling-library-doc-comments": "warn",
        "non-constant-identifier-names": "warn",
        "prefer-generic-function-type-aliases": "warn",
        "prefer-is-empty": "warn",
        "prefer-is-not-empty": "warn",
        "prefer-iterable-where-type": "warn",
        "prefer-typing-uninitialized-variables": "warn",
        "provide-deprecation-message": "warn",
        "unintended-html-in-doc-comment": "warn",
        "use-string-in-part-of-directives": "warn",
        "avoid-init-to-null": "warn",
        "avoid-return-types-on-setters": "warn",
        "avoid-single-cascade-in-expression-statements": "warn",
        "constant-identifier-names": "warn",
        "empty-constructor-bodies": "warn",
        "library-prefixes": "warn",
        "no-leading-underscores-for-library-prefixes": "warn",
        "no-leading-underscores-for-local-identifiers": "warn",
        "prefer-adjacent-string-concatenation": "warn",
        "prefer-collection-literals": "warn",
        "prefer-final-fields": "warn",
        "prefer-function-declarations-over-variables": "warn",
        "prefer-initializing-formals": "warn",
        "prefer-inlined-adds": "warn",
        "prefer-is-not-operator": "warn",
        "prefer-spread-collections": "warn",
        "slash-for-doc-comments": "warn",
        "type-init-formals": "warn",
        "unnecessary-brace-in-string-interps": "warn",
        "unnecessary-constructor-name": "warn",
        "unnecessary-late": "warn",
        "unnecessary-library-name": "warn",
        "unnecessary-new": "warn",
        "unnecessary-nullable-for-final-variable-declarations": "warn",
        "unnecessary-string-escapes": "warn",
        "unnecessary-string-interpolations": "warn",
        "unnecessary-this": "warn",
        "use-function-type-syntax-for-parameters": "warn",
        "use-super-parameters": "warn",
        "avoid-late-keyword": "warn",
        "avoid-non-null-assertion": "warn",
        "avoid-top-level-member-access": "warn",
        "avoid-abbreviations-in-doc-comments": "warn",
        "avoid-positional-fields-in-records": "warn",
        "avoid-redundant-pattern-field-names": "warn",
        "avoid-single-child-column-or-row": "warn",
        "binary-expression-operand-order": "warn",
        "boolean-prefixes": "warn",
        "class-members-ordering": "warn",
        "double-literal-format": "warn",
        "format-comment": "warn",
        "member-ordering": "warn",
        "newline-before-return": "warn",
        "no-magic-number": "warn",
        "no-object-declaration": "warn",
        "prefer-async-await": "warn",
        "prefer-correct-identifier-length": "warn",
        "prefer-correct-type-name": "warn",
        "prefer-first": "warn",
        "prefer-iterable-of": "warn",
        "prefer-last": "warn",
        "prefer-trailing-comma": "warn",
        "prefer-async-callback": "warn",
        "prefer-dedicated-media-query-methods": "warn",
        "prefer-underscore-for-unused-callback-parameters": "warn",
        "use-design-system-item": "warn",
        "use-spacer-as-expanded-child": "warn"
      },
      "suspicious": {
        "avoid-print": "warn",
        "avoid-empty-else": "warn",
        "avoid-shadowing-type-parameters": "warn",
        "empty-catches": "warn",
        "no-wildcard-variable-uses": "warn",
        "avoid-returning-null-for-void": "warn",
        "control-flow-in-finally": "warn",
        "empty-statements": "warn",
        "recursive-getters": "warn",
        "unnecessary-null-aware-assignments": "warn",
        "unnecessary-null-in-if-null-operators": "warn",
        "use-rethrow-when-possible": "warn",
        "avoid-dynamic": "warn",
        "avoid-ignoring-return-values": "warn",
        "avoid-passing-async-when-sync-expected": "warn",
        "avoid-throw-in-catch-block": "warn",
        "avoid-unrelated-type-assertions": "warn",
        "no-empty-block": "warn",
        "no-equal-arguments": "warn",
        "no-equal-then-else": "warn",
        "no-duplicate-case-values": "warn",
        "no-self-comparisons": "warn"
      }
    }
  },
  "project": {
    "enabled": true,
    "rules": {
      "correctness": {
        "unnecessary-nullable": "warn",
        "unused-code": "warn",
        "unused-files": "warn"
      }
    }
  },
  "max_errors": null
}
